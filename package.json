{
  "name": "navigps-pro",
  "version": "1.0.0",
  "description": "eMarinersApp SeaGPS Pro — Maritime Navigation with Multi-Constellation GNSS",
  "main": "index.html",
  "scripts": {
    "test": "node --test tests/unit/*.test.js",
    "test:watch": "node --test --watch tests/unit/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/unit/*.test.js",
    "lint": "for f in js/*.js; do node --check \"$f\" || exit 1; done",
    "build": "npx cap sync",
    "build:android": "npx cap sync android && npx cap open android",
    "build:ios": "npx cap sync ios && npx cap open ios",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "pretest": "echo 'Running SeaGPS Pro test suite...'"
  },
  "author": "eMarinersApp",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@capacitor-community/keep-awake": "^5.0.0",
    "@capacitor/android": "^6.1.0",
    "@capacitor/cli": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/motion": "^6.0.0",
    "@capacitor/screen-orientation": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
