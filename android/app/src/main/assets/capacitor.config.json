{
	"appId": "com.emarinersapp.navigpspro",
	"appName": "SeaGPS Pro",
	"webDir": "www",
	"server": {
		"androidScheme": "https",
		"iosScheme": "capacitor",
		"allowNavigation": [
			"*"
		]
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"launchAutoHide": true,
			"backgroundColor": "#0a1628",
			"androidSplashResourceName": "splash",
			"showSpinner": true,
			"spinnerColor": "#00e676"
		},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#0a1628"
		},
		"ScreenOrientation": {},
		"KeepAwake": {}
	},
	"android": {
		"allowMixedContent": true,
		"backgroundColor": "#0a1628"
	},
	"ios": {
		"backgroundColor": "#0a1628",
		"contentInset": "always",
		"preferredContentMode": "mobile",
		"scheme": "SeaGPS Pro"
	}
}
